{
  "name": "twe",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "bun test",
    "test:unit": "bun test --preload ./src/tests/bun-preload.ts src/tests/unit",
    "test:integration": "TEST_DATABASE_URL=postgresql://twe_test:twe_password@localhost:5433/twe_test bun test src/tests/integration",
    "test:ci": "podman compose up -d postgres_test && (bun run test:unit && bun run test:integration); EXIT_CODE=$?; podman compose stop postgres_test; exit $EXIT_CODE",
    "test:legacy": "bun test src/tests/verify-challenges.test.tsx --preload ./src/tests/setup.ts --dom",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed:basic": "bun run src/db/seed-basic-challenges.ts",
    "db:seed:tutorials": "bun run src/db/seed-tutorials.ts",
    "db:seed:beginner": "bun run src/db/seed-beginner-challenges.ts",
    "db:seed:intermediate": "bun run src/db/seed-intermediate-challenges.ts",
    "db:seed:expert": "bun run src/db/seed-expert-challenges.ts",
    "db:seed:achievements": "bun run src/db/seed-achievements.ts",
    "db:seed:all": "bun run src/db/seed-all.ts",
    "staging:up": "podman compose up -d postgres_staging && sleep 3 && cp .env.staging .env && bunx drizzle-kit push --force && bun run db:seed:all",
    "staging:down": "podman compose stop postgres_staging",
    "staging:reset": "podman compose down postgres_staging -v && npm run staging:up"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.544.0",
    "monaco-editor": "^0.55.1",
    "nitro": "latest",
    "nodemailer": "^7.0.11",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.68.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@happy-dom/global-registrator": "^20.0.11",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.0.11",
    "prettier": "^3.7.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.1.7"
  }
}