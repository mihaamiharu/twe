# Production Database (Self-Hosted via Docker)
DATABASE_URL="postgresql://twe_user:twe_password@postgres:5432/twe_db"
# Direct URL is same as DATABASE_URL for standard Postgres without PgBouncer
DIRECT_URL="postgresql://twe_user:twe_password@postgres:5432/twe_db"

# BetterAuth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-production-secret-here"
BETTER_AUTH_URL="https://your-domain.com"

# Google OAuth Configuration (Optional)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Gmail SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"
SMTP_FROM="TestingWithEkki <your-gmail@gmail.com>"

# Admin email for bug report notifications
ADMIN_EMAIL="your-email@gmail.com"

# Google Analytics
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Node Environment
NODE_ENV="production"
