# Database Configuration
# Local Development (Podman) - default
DATABASE_URL="postgresql://twe_user:twe_password@localhost:5432/twe_db"

# Supabase Production (use in .env.production)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# BetterAuth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
REQUIRE_EMAIL_VERIFICATION="false"

# Google OAuth Configuration (Optional - disabled by default)
# Get credentials from: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. Copy Client ID and Secret below
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Gmail SMTP Configuration
# For Gmail, you need to:
# 1. Enable 2FA on your Google account
# 2. Go to Security → App passwords
# 3. Generate password for "Mail" app
# 4. Use the 16-character password as SMTP_PASSWORD
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASSWORD="your-16-char-app-password"
SMTP_FROM="TestingWithEkki <your-gmail@gmail.com>"

# GitHub Issues integration
GH_TOKEN="your-github-personal-access-token"
GH_OWNER="your-github-username-or-org"
GH_REPO="your-repo-name"

# Admin email for bug report notifications (Optional - used for legacy email reports)
ADMIN_EMAIL="your-email@gmail.com"

# Google Analytics
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Node Environment
NODE_ENV="development"

# E2E Testing Secret (Must match what GitHub Actions passes during tests)
E2E_SECRET="your-e2e-secret-key-here"

# DeepSeek AI Configuration (for AI hints)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="your-deepseek-api-key"
